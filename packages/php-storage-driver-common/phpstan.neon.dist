includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon
    - phpstan-baseline.neon

parameters:
    level: max
    paths:
        - contract
        - tests
        - Shared
    excludePaths:
        analyseAndScan:
            - tests/generated/*
    ignoreErrors:
