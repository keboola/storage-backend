includes:
    - phpstan-baseline.neon

parameters:
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - identifier: method.alreadyNarrowedType
          path: tests/Functional/*
        - identifier: function.alreadyNarrowedType
          path: tests/Functional/*
        - identifier: instanceof.alwaysTrue
          path: tests/Functional/*
